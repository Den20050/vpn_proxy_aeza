{
  "urltest": {
    "url": "https://www.gstatic.com/generate_204",
    "interval": "1m",
    "tolerance": 50,
    "idle_timeout": "15m",
    "interrupt_exist_connections": true
  },
  "endpoints": [
    {
      "tag": "vless-debian",
      "server_name": "www.debian.org",
      "port": 443,
      "tier": "primary",
      "note": "Основной SNI и vless://. Open-source, стабильный TLS, обычно доступен из РФ, низкая нагрузка в DPI."
    },
    {
      "tag": "vless-mozilla",
      "server_name": "addons.mozilla.org",
      "port": 8443,
      "tier": "rf-friendly",
      "note": "FOSS, умеренный трафик, редко в списках блокировок."
    },
    {
      "tag": "vless-kernel",
      "server_name": "www.kernel.org",
      "port": 8444,
      "tier": "rf-friendly",
      "note": "Нишевый техдомен, стабильный TLS 1.3."
    },
    {
      "tag": "vless-jsdelivr",
      "server_name": "cdn.jsdelivr.net",
      "port": 8445,
      "tier": "rf-friendly",
      "note": "Публичный CDN для npm/github — не FAANG."
    },
    {
      "tag": "vless-nvidia",
      "server_name": "www.nvidia.com",
      "port": 8446,
      "tier": "rf-friendly",
      "note": "Железо/драйверы, умеренный профиль трафика."
    },
    {
      "tag": "vless-ms",
      "server_name": "www.microsoft.com",
      "port": 8447,
      "tier": "backup",
      "note": "Резерв; популярный SNI — только через urltest/failover, не в новых QR."
    }
  ]
}
